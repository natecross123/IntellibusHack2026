# BreachBuddy Environment Variables
# Copy this file to .env and fill in your own keys

# --- Google Safe Browsing ---
# Get key at: https://console.cloud.google.com → Enable Safe Browsing API
GOOGLE_SAFE_BROWSING_API_KEY=

# --- VirusTotal ---
# Free tier at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# --- Google Gemini / Groq ---
GROQ_API_KEY=

# --- App Config ---
APP_ENV=development
